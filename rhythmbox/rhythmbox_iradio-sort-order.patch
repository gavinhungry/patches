+	/* Apply the persistent, user-defined manual sort order.  The order is
+	 * stored per-station in RHYTHMDB_PROP_TRACK_NUMBER (which iradio does
+	 * not otherwise use) so it is saved to rhythmdb.xml, and can be edited
+	 * by hand there to set the order.  Applying it on every query means the
+	 * order survives genre filtering, searching and restarts.  Stations
+	 * with no track-number (0) sort to the top.
+	 *
+	 * This must be called AFTER rb_entry_view_set_model, because that
+	 * function calls rb_entry_view_resort_model internally (when a sorting
+	 * column is already set), which would overwrite our custom sort.
+	 */
+	rhythmdb_query_model_set_sort_order (station_query_model,
+					     (GCompareDataFunc) rb_iradio_source_order_sort_func,
+					     NULL, NULL, FALSE);
 	g_object_set (source, "query-model", station_query_model, NULL);
 
 	g_object_unref (genre_query_model);
