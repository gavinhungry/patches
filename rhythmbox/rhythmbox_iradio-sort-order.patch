+/*
+ * Sort comparator for the persistent manual station order.
+ *
+ * The order index is stored per-station in RHYTHMDB_PROP_TRACK_NUMBER.  Ties
+ * (e.g. stations that have not yet been assigned an index) are broken by title
+ * and then location so the order is stable.
+ */
+static gint
+rb_iradio_source_order_sort_func (RhythmDBEntry *a, RhythmDBEntry *b, gpointer data)
+{
+	gulong a_num, b_num;
+	const char *a_val, *b_val;
+
+	a_num = rhythmdb_entry_get_ulong (a, RHYTHMDB_PROP_TRACK_NUMBER);
+	b_num = rhythmdb_entry_get_ulong (b, RHYTHMDB_PROP_TRACK_NUMBER);
+	if (a_num != b_num)
+		return (a_num < b_num ? -1 : 1);
+
+	a_val = rhythmdb_entry_get_string (a, RHYTHMDB_PROP_TITLE_SORT_KEY);
+	b_val = rhythmdb_entry_get_string (b, RHYTHMDB_PROP_TITLE_SORT_KEY);
+	if (a_val != NULL && b_val != NULL) {
+		int ret = strcmp (a_val, b_val);
+		if (ret != 0)
+			return ret;
+	}
+
+	a_val = rhythmdb_entry_get_string (a, RHYTHMDB_PROP_LOCATION);
+	b_val = rhythmdb_entry_get_string (b, RHYTHMDB_PROP_LOCATION);
+	if (a_val == NULL || b_val == NULL)
+		return 0;
+	return strcmp (a_val, b_val);
+}
