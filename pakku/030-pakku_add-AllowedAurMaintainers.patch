+proc checkAllowedAurMaintainers(config: Config,
+  basePackages: seq[seq[seq[PackageInfo]]]): bool =
+  # Returns true if all AUR build packages have an allowed maintainer, or if the
+  # feature is disabled (empty allow-list). This runs before any PKGBUILD or
+  # included-file code can execute, so untrusted packages are never built.
+  if config.allowedAurMaintainers.len == 0:
+    return true
+
+  let pkgInfos = collect(newSeq):
+    for g in basePackages:
+      for b in g:
+        for i in b:
+          i
+
+  var allowed = true
+  for pkgInfo in pkgInfos:
+    let maintainer = pkgInfo.rpc.maintainer
+    if maintainer.isNone or maintainer.unsafeGet.strip.len == 0:
+      printWarning(config.color,
+        tr"$# has no maintainer; skipping" % [pkgInfo.rpc.name])
+      allowed = false
+    elif maintainer.unsafeGet notin config.allowedAurMaintainers:
+      printWarning(config.color,
+        tr"$#: maintainer '$#' not in AllowedAurMaintainers; skipping" %
+        [pkgInfo.rpc.name, maintainer.unsafeGet])
+      allowed = false
+
+  if not allowed:
+    printError(config.color, tr"skipped packages without allowed maintainers")
+
+  allowed
