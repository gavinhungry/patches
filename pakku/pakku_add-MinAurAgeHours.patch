     .map(r => s.target.reference.isProvidedBy(r, true)).get(false)))
 
+proc tooNew*(config: Config, rpc: RpcPackageInfo, now: int64): bool =
+  ## Returns true if `rpc.lastModified` is newer than (now - minAurAgeHours hours).
+  ## Returns false when the check is disabled (minAurAgeHours <= 0) or when
+  ## LastModified is missing from the RPC response (permissive default).
+  if config.minAurAgeHours <= 0:
+    false
+  else:
+    rpc.lastModified.map(t => now - t < int64(config.minAurAgeHours) * 3600).get(false)
+
+proc ageHours(rpc: RpcPackageInfo, now: int64): Option[int64] =
+  ## Package age in (rounded-down) whole hours since LastModified.
+  rpc.lastModified.map(t => (now - t) div 3600)
+
+proc ageHoursStr*(rpc: RpcPackageInfo, now: int64): string =
+  ## Human-friendly age string for use in user-facing warnings/prompts.
+  ## Returns "1 hour" (singular), "N hours" (plural), or "? hours" when
+  ## LastModified is unavailable.
+  let age = rpc.ageHours(now)
+  if age.isNone:
+    "? hours"
+  elif age.unsafeGet == 1:
+    "1 hour"
+  else:
+    $age.unsafeGet & " hours"
+
